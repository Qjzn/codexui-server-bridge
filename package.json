{
  "name": "codexapp",
  "version": "2.1.3",
  "description": "OpenAI Codex web UI and browser bridge for Windows, Linux, Android, LAN, and remote self-hosted access",
  "type": "module",
  "license": "MIT",
  "author": "Pavel Voronin, Igor Levochkin, and contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Qjzn/codexui-server-bridge.git"
  },
  "homepage": "https://github.com/Qjzn/codexui-server-bridge#readme",
  "bugs": {
    "url": "https://github.com/Qjzn/codexui-server-bridge/issues"
  },
  "keywords": [
    "codex",
    "openai",
    "openai-codex",
    "codex-ui",
    "codex-web",
    "web-ui",
    "browser-ui",
    "remote",
    "remote-access",
    "self-hosted",
    "windows",
    "windows-server",
    "linux",
    "android",
    "termux",
    "lan",
    "cli",
    "mobile-browser",
    "cloudflare-tunnel",
    "self-hosted-codex",
    "windows-friendly",
    "remote-development",
    "ai-coding-agent"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "codexapp": "dist-cli/index.js",
    "codexui": "dist-cli/index.js"
  },
  "files": [
    "dist/",
    "dist-cli/"
  ],
  "scripts": {
    "dev": "pnpm install && vite",
    "dev:open": "pnpm run build:cli && sh -c 'pnpm run dev & VPID=$!; node dist-cli/index.js --open-project \"${1:-.}\"; wait $VPID' --",
    "build:frontend": "vue-tsc --noEmit && vite build",
    "build:cli": "tsup",
    "build": "npm run build:frontend && npm run build:cli",
    "mobile:android:add": "npx cap add android",
    "mobile:android:sync": "npm run build:frontend && npx cap sync android",
    "mobile:android:open": "npx cap open android",
    "mobile:android:run": "npm run mobile:android:sync && npx cap run android",
    "package:release": "powershell -ExecutionPolicy Bypass -File ./scripts/package-release.ps1",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File ./setup.ps1",
    "test:7420": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/regression-7420.ps1",
    "test:7420:soak": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/soak-7420.ps1",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/network": "^8.0.1",
    "commander": "^13.1.0",
    "express": "^5.1.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.2",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.2.0"
  }
}
